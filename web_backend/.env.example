BACKEND_HOST=0.0.0.0
BACKEND_PORT=18080

# Required upstream URLs for containerized backend (no defaults):
# examples:
# CAR_NUMBER_API_URL=http://192.168.1.10:11436/recognize
# TIRE_NUMBER_API_URL=http://ml.example.com:11435/recognize
# TIRE_ANALYSIS_API_URL=http://ml.example.com:11437/analyze
CAR_NUMBER_API_URL=
TIRE_NUMBER_API_URL=
TIRE_ANALYSIS_API_URL=

UPSTREAM_TIMEOUT_SEC=120
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

PROJECT_ROOT=.
USERS_DIR=Users
ATWORK_DIR=AtWork
CAR_NUMBER_FILE_PATH=dir_json/car_number.json
DEMO_IMG_DIR=DEMO_img

BASE_URL=
BASE_TEST=
ADMIN_USERNAME=
ADMIN_PASSWORD=
LOG_UPLOAD_DIR=log_upload

S3_SYNC_MODE=on_demand
S3_SYNC_VERBOSE=false
S3_PREFIX=AITyres/users/
S3_BUCKET_NAME=rgtelegram
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
YC_ENDPOINT_URL=https://storage.yandexcloud.net
YC_REGION=ru-central1
